<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Добавление вопроса"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/question_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Текст вопроса *"
            android:minLines="2"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@android:drawable/editbox_background" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Варианты ответов:"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/option_a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="A. Вариант ответа"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="@android:drawable/editbox_background" />

        <EditText
            android:id="@+id/option_b"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="B. Вариант ответа"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="@android:drawable/editbox_background" />

        <EditText
            android:id="@+id/option_c"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="C. Вариант ответа"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="@android:drawable/editbox_background" />

        <EditText
            android:id="@+id/option_d"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="D. Вариант ответа"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:background="@android:drawable/editbox_background" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Правильный ответ: *"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/correct_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/correct_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A" />

            <RadioButton
                android:id="@+id/correct_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="B" />

            <RadioButton
                android:id="@+id/correct_c"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="C" />

            <RadioButton
                android:id="@+id/correct_d"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="D" />

        </RadioGroup>

        <Button
            android:id="@+id/add_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="+ ДОБАВИТЬ ВОПРОС"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/colorGreeny" />

        <Button
            android:id="@+id/finish_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="✅ ЗАВЕРШИТЬ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/colorAccent" />

    </LinearLayout>

</ScrollView>