<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Главная тема для всего приложения - без ActionBar -->
    <style name="Theme.BRICSCourses" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Статус-бар -->
        <item name="android:statusBarColor">@color/colorGreeny</item>

        <!-- ВАЖНО: отключаем прозрачность -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>

        <!-- Делает текст в меню черным -->
        <item name="android:textColorPrimary">@android:color/black</item>

        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:colorBackground">@android:color/white</item>
    </style>
</resources>